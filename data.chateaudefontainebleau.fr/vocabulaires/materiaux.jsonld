es/materiaux/concept_127","prefLabel":{"fr":"Jaspe rose"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_128","prefLabel":{"fr":"Jaspe sanguin"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_129","prefLabel":{"fr":"Jaspe vert"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_130","prefLabel":{"fr":"Lapis-lazuli"},"hiddenLabel":{"fr":["Lapis"]}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_131","prefLabel":{"fr":"Rubis"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_132","prefLabel":{"fr":"Saphir"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_133","prefLabel":{"fr":"Sardoine"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_134","prefLabel":{"fr":"Topaze"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_135","prefLabel":{"fr":"Turquoise"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_136","prefLabel":{"fr":"Stuc"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_137","prefLabel":{"fr":"Terre"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_138","prefLabel":{"fr":"Terre crue"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_139","prefLabel":{"fr":"Terre cuite"},"hiddenLabel":{"fr":["Terre-cuite"]},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_140","prefLabel":{"fr":"Céramique"},"hiddenLabel":{"fr":["Terre vernissée"]},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_141","prefLabel":{"fr":"Faïence"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_142","prefLabel":{"fr":"Faïence fine"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_143","prefLabel":{"fr":"Grès (céramique)"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_144","prefLabel":{"fr":"Porcelaine"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_145","prefLabel":{"fr":"Biscuit de porcelaine"}}]}]}]}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_148","prefLabel":{"fr":"Verre"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_149","prefLabel":{"fr":"Cristal"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_150","prefLabel":{"fr":"Cristal de Montcenis"},"hiddenLabel":{"fr":["Cristal de Mont-Cenis"]},"definition":{"fr":"Cristaux Creusot ou Montcenis.\nIl existe très peu de pièces authentifiées comme des productions de la manufacture du Creusot (qui porte jusqu'à sa fermeture le nom de cristallerie de Montcenis). Les seuls catalogues connus à ce jour ne permettent pas d'être complètement affirmatif. En 1823, est même édité, sous la forme d'une liste de produits courants, un catalogue commun à Baccarat et Montcenis. Le seul catalogue que l'on peut estimer de 1830 ne présente que des formes et des mentions de tailles. A cette date les principales cristalleries françaises ont des productions similaires correspondant au goût et aux modes du moment (Source:www.ecomusee-creusot-montceau.fr).\nLa manufacture des cristaux de Montcenis au Creusot a été récompensée à deux reprises aux Expositions des produits de l’industrie française, en 1801 et 1802. A partir de 1806, son administrateur, Benjamin-François de la Douespe du Fougerais (1766-1821) devient le principal fournisseur de verrerie de l’Impératrice Il prend alors le titre d’« Entrepreneur de cristaux de S. M. l’Impératrice ». Il fournit abondamment également, tant la Maison de l ‘Empereur, que celle de la reine Hortense (Musée national des châteaux de Malmaison et Bois- Préau)."}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_151","prefLabel":{"fr":"Strass"}}]}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_152","prefLabel":{"fr":"Matériau d'origine animale"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_153","prefLabel":{"fr":"Cheveux"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_154","prefLabel":{"fr":"Cire"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_155","prefLabel":{"fr":"Coquillage"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_156","prefLabel":{"fr":"Nacre"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_157","prefLabel":{"fr":"Corail"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_158","prefLabel":{"fr":"Corne"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_159","prefLabel":{"fr":"Fanon de baleine"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_160","prefLabel":{"fr":"Crin"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_161","prefLabel":{"fr":"Cuir"},"hiddenLabel":{"fr":["Peau"]},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_162","prefLabel":{"fr":"Maroquin"},"scopeNote":{"fr":["Cuir de chèvre épaisse et solide, utilisé en reliure et en maroquinerie."]}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_163","prefLabel":{"fr":"Parchemin"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_164","prefLabel":{"fr":"Vélin"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_165","prefLabel":{"fr":"Ecaille"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_166","prefLabel":{"fr":"Ivoire (dent)"},"scopeNote":{"fr":["\"Dent\" permet de différencier de ivoire \"couleur\"."]}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_167","prefLabel":{"fr":"Laine"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_168","prefLabel":{"fr":"Cachemire"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_169","prefLabel":{"fr":"Lin"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_170","prefLabel":{"fr":"Os"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_171","prefLabel":{"fr":"Os de baleine"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_172","prefLabel":{"fr":"Plume"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_173","prefLabel":{"fr":"Sépia"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_174","prefLabel":{"fr":"Soie"}}]},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_175","prefLabel":{"fr":"Précisions matériaux"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_176","prefLabel":{"fr":"Application et incrustation"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_177","prefLabel":{"fr":"Biais"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_178","prefLabel":{"fr":"Cabochon"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_179","prefLabel":{"fr":"Cannetille"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_180","prefLabel":{"fr":"Frange"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_181","prefLabel":{"fr":"Galon"}},{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_182","prefLabel":{"fr":"Paillette"},"narrower":[{"id":"http://data.chateaudefontainebleau.fr/vocabulaires/materiaux/concept_183","prefLabel":{"fr":"Paillon"}}]},{"id":"http://data.ch